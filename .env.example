# Copy this file to `.env` in the project root and fill in values.
# `.env` is gitignored — never commit real secrets.

# Required: API key (xAI Grok and Groq both use this variable name)
GROK_API_KEY=

# Use xAI Grok (console.x.ai) — set this if you want Grok, especially if your key also looks like a Groq key:
GROK_PROVIDER=xai

# Optional model (xAI: e.g. grok-4, grok-4-latest — match the Models page in console.x.ai)
# GROK_MODEL=grok-4

# Optional — if GROK_PROVIDER is unset, auto mode is used:
# - Keys starting with gsk_ → Groq unless GROK_PROVIDER=xai
# - Other keys → xAI Grok
#
# GROK_PROVIDER=groq
# GROK_API_URL=https://api.x.ai/v1/chat/completions

# Optional: reduce completion tokens to fit provider TPM limits (default: 1024 on Groq, 2048 on xAI)
# GROK_MAX_COMPLETION_TOKENS=1024
